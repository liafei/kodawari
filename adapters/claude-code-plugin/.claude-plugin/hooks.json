{
  "schema_version": "claude.hooks.v1",
  "policy_schema_version": "execution.guard.policy.v1",
  "policy_name": "default",
  "hooks": {
    "PreToolUse": [
      {
        "id": "deny_001",
        "action": "deny",
        "pattern": "\\bsudo\\b",
        "reason": "Sudo commands blocked"
      },
      {
        "id": "deny_002",
        "action": "deny",
        "pattern": "rm\\s+-rf\\s+/",
        "reason": "rm -rf / blocked"
      },
      {
        "id": "deny_003",
        "action": "deny",
        "pattern": "git\\s+push\\s+--force",
        "reason": "Force push blocked"
      },
      {
        "id": "deny_004",
        "action": "deny",
        "pattern": "git\\s+reset\\s+--hard\\s+(main|master)",
        "reason": "Hard reset to protected branch blocked"
      },
      {
        "id": "deny_005",
        "action": "deny",
        "pattern": "git\\s+branch\\s+-D\\s+(main|master)",
        "reason": "Delete protected branch blocked"
      },
      {
        "id": "deny_006",
        "action": "deny",
        "pattern": "git\\s+clean\\s+-fdx",
        "reason": "Destructive workspace clean blocked"
      },
      {
        "id": "deny_007",
        "action": "deny",
        "pattern": "--no-verify",
        "reason": "Bypassing git safety hooks blocked"
      },
      {
        "id": "deny_008",
        "action": "deny",
        "pattern": "(id_rsa|id_ed25519|\\.pem|\\.p12|\\.pfx|\\.env)(\\s|$)",
        "reason": "Sensitive credential file mutation blocked"
      },
      {
        "id": "ask_009",
        "action": "ask",
        "pattern": "rm\\s+-rf",
        "reason": "Recursive delete requires confirmation"
      },
      {
        "id": "ask_010",
        "action": "ask",
        "pattern": "git\\s+push(?!\\s+--force)",
        "reason": "Push requires confirmation"
      },
      {
        "id": "ask_011",
        "action": "ask",
        "pattern": "git\\s+reset\\s+--hard",
        "reason": "Hard reset requires confirmation"
      },
      {
        "id": "ask_012",
        "action": "ask",
        "pattern": "git\\s+checkout\\s+--\\s+",
        "reason": "Discarding file changes requires confirmation"
      },
      {
        "id": "ask_013",
        "action": "ask",
        "pattern": "chmod\\s+-R",
        "reason": "Recursive permission changes require confirmation"
      }
    ]
  }
}
