{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "kodawari worktree baseline",
  "type": "object",
  "required": [
    "schema_version",
    "captured_at",
    "feature",
    "planning_dir",
    "command",
    "mode",
    "status",
    "dirty_files",
    "tracked_dirty_files",
    "untracked_files",
    "allowed_files",
    "core_dirty_files",
    "details"
  ],
  "properties": {
    "schema_version": { "const": "worktree.baseline.v1" },
    "captured_at": { "type": "string", "minLength": 1 },
    "feature": { "type": "string", "minLength": 1 },
    "planning_dir": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["warn", "fail"]
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "WARN", "FAIL"]
    },
    "dirty_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tracked_dirty_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "untracked_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "core_dirty_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "details": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
