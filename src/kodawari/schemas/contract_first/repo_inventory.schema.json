{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "project_root",
    "mode",
    "archetype",
    "capabilities",
    "project_layout",
    "surfaces",
    "verify_surfaces"
  ],
  "properties": {
    "schema_version": {
      "const": "contract_first.repo_inventory.v1"
    },
    "generated_at": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "auto",
        "existing",
        "greenfield"
      ]
    },
    "archetype": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "package_managers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "project_layout": {
      "type": "object"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "roots",
          "verify_command"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "framework": {
            "type": "string"
          },
          "roots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verify_command": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "verify_surfaces": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
