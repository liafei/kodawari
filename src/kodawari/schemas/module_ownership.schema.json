{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "kodawari module ownership",
  "type": "object",
  "required": ["modules"],
  "additionalProperties": false,
  "properties": {
    "modules": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["owner", "path", "public_api", "description", "forbidden_imports", "canonical_for"],
        "additionalProperties": true,
        "properties": {
          "owner": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "public_api": {
            "type": "array",
            "items": {"type": "string"},
            "default": []
          },
          "description": {"type": "string", "default": ""},
          "forbidden_imports": {
            "type": "array",
            "items": {"type": "string"},
            "default": []
          },
          "canonical_for": {
            "type": "array",
            "items": {"type": "string"},
            "default": []
          }
        }
      }
    }
  }
}
