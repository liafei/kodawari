{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec",
  "type": "object",
  "required": ["spec_id", "spec_version", "prd_clause", "epic", "priority", "spec_types"],
  "properties": {
    "spec_id": { "type": "string", "minLength": 1 },
    "spec_version": { "type": "string", "minLength": 1 },
    "prd_clause": { "type": "string", "minLength": 1 },
    "epic": { "type": "string", "minLength": 1 },
    "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
    "spec_types": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "algorithm": { "type": "array", "items": { "type": "object" } },
    "data_structure": { "type": "array", "items": { "type": "object" } },
    "api_contract": { "type": "array", "items": { "type": "object" } },
    "acceptance_tests": { "type": "array", "items": { "type": "object" } },
    "dependencies": { "type": "array", "items": { "type": "object" } },
    "risks": { "type": "array", "items": { "type": "object" } },
    "assumptions": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
